{
  "__inputs": [{ "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" }],
  "description": "Sentiment Analysis MLOps - Full monitoring dashboard",
  "editable": true,
  "panels": [
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "id": 100, "title": "API Health & Status", "type": "row" },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "mappings": [{ "options": { "0": { "color": "red", "text": "DOWN" }, "1": { "color": "green", "text": "UP" } }, "type": "value" }], "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] } } }, "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 }, "id": 1, "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } }, "title": "API Status", "type": "stat", "targets": [{ "expr": "up{job=\"sentiment_backend\"}", "legendFormat": "API", "refId": "A" }] },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "mappings": [{ "options": { "0": { "color": "red", "text": "NOT LOADED" }, "1": { "color": "green", "text": "LOADED" } }, "type": "value" }], "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] } } }, "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 }, "id": 2, "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } }, "title": "Model Status", "type": "stat", "targets": [{ "expr": "sentiment_model_loaded", "legendFormat": "Model", "refId": "A" }] },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "mappings": [{ "options": { "0": { "color": "orange", "text": "DISCONNECTED" }, "1": { "color": "green", "text": "CONNECTED" } }, "type": "value" }], "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }, { "color": "green", "value": 1 }] } } }, "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 }, "id": 3, "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } }, "title": "MLflow Status", "type": "stat", "targets": [{ "expr": "sentiment_mlflow_connected", "legendFormat": "MLflow", "refId": "A" }] },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "reqps" } }, "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 }, "id": 4, "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }, "title": "Request Rate", "type": "stat", "targets": [{ "expr": "sum(rate(sentiment_request_total[1m]))", "legendFormat": "req/s", "refId": "A" }] },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "ms", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 200 }] } } }, "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 }, "id": 5, "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }, "title": "p99 Latency (ms)", "type": "stat", "targets": [{ "expr": "histogram_quantile(0.99, rate(sentiment_prediction_latency_seconds_bucket[5m])) * 1000", "legendFormat": "p99", "refId": "A" }] },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "percentunit", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.03 }, { "color": "red", "value": 0.05 }] } } }, "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 }, "id": 6, "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }, "title": "Error Rate", "type": "stat", "targets": [{ "expr": "rate(sentiment_prediction_errors_total[5m]) / (rate(sentiment_predictions_total[5m]) + 0.001)", "legendFormat": "errors", "refId": "A" }] },
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }, "id": 101, "title": "Request & Latency", "type": "row" },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "reqps" } }, "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 }, "id": 10, "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } }, "title": "Request Rate by Endpoint", "type": "timeseries", "targets": [{ "expr": "sum by(endpoint) (rate(sentiment_request_total[1m]))", "legendFormat": "{{endpoint}}", "refId": "A" }] },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "ms" } }, "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 }, "id": 11, "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } }, "title": "Inference Latency Percentiles", "type": "timeseries", "targets": [{ "expr": "histogram_quantile(0.50, rate(sentiment_prediction_latency_seconds_bucket[5m])) * 1000", "legendFormat": "p50", "refId": "A" }, { "expr": "histogram_quantile(0.90, rate(sentiment_prediction_latency_seconds_bucket[5m])) * 1000", "legendFormat": "p90", "refId": "B" }, { "expr": "histogram_quantile(0.99, rate(sentiment_prediction_latency_seconds_bucket[5m])) * 1000", "legendFormat": "p99", "refId": "C" }, { "expr": "200", "legendFormat": "SLA 200ms", "refId": "D" }] },
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 }, "id": 102, "title": "Sentiment Distribution", "type": "row" },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "short" } }, "gridPos": { "h": 8, "w": 8, "x": 0, "y": 15 }, "id": 20, "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] }, "pieType": "pie" }, "title": "Live Sentiment Distribution", "type": "piechart", "targets": [{ "expr": "sum by(sentiment) (increase(sentiment_predictions_total[1h]))", "legendFormat": "{{sentiment}}", "refId": "A" }] },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "short" } }, "gridPos": { "h": 8, "w": 16, "x": 8, "y": 15 }, "id": 21, "options": { "legend": { "calcs": ["mean"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } }, "title": "Prediction Volume by Sentiment", "type": "timeseries", "targets": [{ "expr": "sum by(sentiment) (rate(sentiment_predictions_total[5m]))", "legendFormat": "{{sentiment}}", "refId": "A" }] },
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 }, "id": 103, "title": "Data Drift Detection", "type": "row" },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "min": 0, "max": 1, "unit": "percentunit", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.2 }, { "color": "orange", "value": 0.3 }, { "color": "red", "value": 0.6 }] } } }, "gridPos": { "h": 6, "w": 8, "x": 0, "y": 24 }, "id": 30, "options": { "showThresholdLabels": true, "showThresholdMarkers": true, "reduceOptions": { "calcs": ["lastNotNull"] } }, "title": "Data Drift Score", "type": "gauge", "targets": [{ "expr": "max(sentiment_data_drift_score)", "legendFormat": "drift", "refId": "A" }] },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "none" } }, "gridPos": { "h": 6, "w": 16, "x": 8, "y": 24 }, "id": 31, "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } }, "title": "Sentiment Distribution Ratio Over Time", "type": "timeseries", "targets": [{ "expr": "sentiment_label_distribution_ratio", "legendFormat": "{{sentiment}}", "refId": "A" }] },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "none" } }, "gridPos": { "h": 6, "w": 24, "x": 0, "y": 30 }, "id": 32, "options": { "legend": { "calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } }, "title": "Prediction Confidence Percentiles", "type": "timeseries", "targets": [{ "expr": "histogram_quantile(0.50, rate(sentiment_prediction_confidence_bucket[10m]))", "legendFormat": "p50", "refId": "A" }, { "expr": "histogram_quantile(0.90, rate(sentiment_prediction_confidence_bucket[10m]))", "legendFormat": "p90", "refId": "B" }, { "expr": "histogram_quantile(0.99, rate(sentiment_prediction_confidence_bucket[10m]))", "legendFormat": "p99", "refId": "C" }, { "expr": "0.65", "legendFormat": "Min threshold", "refId": "D" }] },
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 }, "id": 104, "title": "System Resources", "type": "row" },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 85 }] } } }, "gridPos": { "h": 6, "w": 8, "x": 0, "y": 37 }, "id": 40, "options": { "showThresholdMarkers": true, "reduceOptions": { "calcs": ["lastNotNull"] } }, "title": "CPU Usage %", "type": "gauge", "targets": [{ "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)", "refId": "A" }] },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 85 }] } } }, "gridPos": { "h": 6, "w": 8, "x": 8, "y": 37 }, "id": 41, "options": { "showThresholdMarkers": true, "reduceOptions": { "calcs": ["lastNotNull"] } }, "title": "Memory Usage %", "type": "gauge", "targets": [{ "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100", "refId": "A" }] },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 85 }] } } }, "gridPos": { "h": 6, "w": 8, "x": 16, "y": 37 }, "id": 42, "options": { "showThresholdMarkers": true, "reduceOptions": { "calcs": ["lastNotNull"] } }, "title": "Disk Usage %", "type": "gauge", "targets": [{ "expr": "(1 - (node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"})) * 100", "refId": "A" }] }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["sentiment", "mlops", "nlp"],
  "templating": { "list": [{ "hide": 0, "label": "Datasource", "name": "DS_PROMETHEUS", "query": "prometheus", "refresh": 1, "type": "datasource" }] },
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "title": "Sentiment Analysis MLOps Dashboard",
  "uid": "sentiment-mlops-v1",
  "version": 1
}